# VMware vCenter Connection Settings
#
# === Multi-vCenter mode (recommended) ===
# Define one or more named instances. Suffix env vars with the instance name (UPPERCASE).
#
# VCENTER_HOSTS=prod,dr,lab
# VCENTER_DEFAULT=prod                       # optional; first in VCENTER_HOSTS otherwise
#
# VCENTER_HOST_PROD=vcenter-prod.example.com
# VCENTER_USER_PROD=admin@vsphere.local
# VCENTER_PASSWORD_PROD=changeme
#
# VCENTER_HOST_DR=vcenter-dr.example.com
# VCENTER_USER_DR=admin@vsphere.local
# VCENTER_PASSWORD_DR=changeme
#
# VCENTER_HOST_LAB=vcenter-lab.example.com
# VCENTER_USER_LAB=admin@vsphere.local
# VCENTER_PASSWORD_LAB=changeme
#
# Tools accept an optional `instance` parameter (e.g. instance="dr"); omit for default.
# Use the `list_vcenters` tool to see configured instance names.

# === Legacy single-vCenter mode (fallback if VCENTER_HOSTS is not set) ===
VCENTER_HOST=your-vcenter-host.com
VCENTER_USERNAME=your-username
VCENTER_PASSWORD=your-password
VCENTER_PORT=443

# MCP Server Transport Configuration
# MCP_TRANSPORT: Choose transport mode (stdio, sse, http)
#   - stdio: Default mode for local tools like Goose
#   - sse: Server-Sent Events mode for web clients like n8n
#   - http: HTTP mode for web deployments
MCP_TRANSPORT=stdio

# MCP Server Network Configuration (for sse/http modes)
# MCP_HOST: Host to bind to (default: 127.0.0.1)
MCP_HOST=127.0.0.1
# MCP_PORT: Port to bind to (default: 8000)
MCP_PORT=8000
# MCP_PATH: HTTP path for http mode (default: /mcp)
MCP_PATH=/mcp

# === Guest Operations (run_in_guest_via_vix) ===
# Used by the run_in_guest_via_vix tool to execute scripts inside a guest OS
# via the vCenter Guest Operations API. The credentials below are guest OS
# accounts (NOT vCenter accounts), and must have Administrator/root privileges
# in the guest for scripts that install drivers or rebuild initramfs.
#
# Defaults applied when guest_username/guest_password are not passed to the tool:
# GUEST_USERNAME_WINDOWS=Administrator
# GUEST_PASSWORD_WINDOWS=changeme
# GUEST_USERNAME_LINUX=root
# GUEST_PASSWORD_LINUX=changeme
#
# Optional named profiles (selected via the tool's guest_profile arg) for
# tenant/site separation:
# GUEST_USERNAME_WINDOWS_CORP=svc-zertoprep
# GUEST_PASSWORD_WINDOWS_CORP=changeme
# GUEST_USERNAME_LINUX_CORP=zertoprep
# GUEST_PASSWORD_LINUX_CORP=changeme
#
# Future: AD/Kerberos via vim.vm.guest.SAMLTokenAuthentication, and SSH-key
# delivery for Linux as a separate channel.
